@echo off
REM Task B of the BIOS-wake auto-login flow. Registered as a Task Scheduler
REM task triggered "At log on" for the specific local user account. Only
REM proceeds if enable_autologin_and_reboot.bat left the pending-flag (i.e.
REM this really is the automated reboot cycle, not a coincidental normal
REM login that happens to land inside the same time window), and re-checks
REM the time window itself as a second, independent gate.
REM
REM Copy this file to run_after_autologin.bat (gitignored -- never commit
REM real credentials) and fill in --windows-password below with the REMOTE
REM Barco Work Station's Windows login password (NOT this local machine's).

for /f %%d in ('powershell -NoProfile -Command "Get-Date -Format yyyyMMdd"') do set TODAY=%%d
set FLAG=C:\Workspace\BarcoUtils\src\chrome-remote-desktop\.autologin_pending_%TODAY%
if not exist "%FLAG%" exit /b 0
del "%FLAG%"

cd /d "C:\Workspace\BarcoUtils"
python.exe src\chrome-remote-desktop\check_time_window.py --start 08:00 --end 08:45
if errorlevel 1 goto :cleanup


python.exe src\chrome-remote-desktop\remote_login.py --computer-name "Barco Work Station" --program-path "python.exe C:\Project\BarcoUtils\src\timesheet\fill_timesheet2.py" --windows-password YOUR_REMOTE_PASSWORD_HERE

:cleanup
REM The actual gate is the LSA secret (see lsa_secret.ps1 / CLAUDE.md) --
REM clearing it is what stops autologin, confirmed by live testing.
REM AutoAdminLogon=0 is kept too as defense-in-depth even though it alone
REM does not gate autologin for a Microsoft Account.
cd /d "C:\Workspace\BarcoUtils"
powershell -NoProfile -ExecutionPolicy Bypass -File "src\chrome-remote-desktop\lsa_secret.ps1" -Action Clear
reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Winlogon" /v AutoAdminLogon /t REG_SZ /d 0 /f
shutdown /s /t 5

